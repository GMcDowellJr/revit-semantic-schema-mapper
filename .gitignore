__pycache__/
*.pyc
*.egg-info/
.pytest_cache/
build/
dist/
*.tar.gz

# Everything under outputs/ is a regenerable pipeline artifact by default --
# allowlisted below (not blocklisted by filename), so a future pipeline
# stage's new output file, or a brand new outputs/revit_<version>/ folder
# from the next Revit release, is excluded automatically instead of needing
# a new ignore rule added here every time one shows up.
revit_semantic_schema/outputs/*
!revit_semantic_schema/outputs/*/
revit_semantic_schema/outputs/*/*
!revit_semantic_schema/outputs/*/summary.md
!revit_semantic_schema/outputs/*/validation_summary.md
# Small, already-curated illustrative example outputs from earlier work
# (not tied to a real per-version crawl/reflection run) -- kept in full.
!revit_semantic_schema/outputs/_fixture_smoke_test/**
!revit_semantic_schema/outputs/revit_2024_targeted/**
